# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored and must NEVER be committed.
#
# WooCommerce REST API base URL (ends with /wc/v3)
VITE_WC_URL=https://your-store.example/wp-json/wc/v3
#
# Basic-auth token: base64 of "consumer_key:consumer_secret".
# Generate a NEW key in WooCommerce > Settings > Advanced > REST API.
VITE_WC_AUTH=replace_with_base64_of_key:secret
